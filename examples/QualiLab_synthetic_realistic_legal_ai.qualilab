      "author_name": "Júlia"
    },
    {
      "id": "c32",
      "document_id": "doc-4",
      "code_id": "code-b1",
      "span_start": 518,
      "span_end": 588,
      "quote": "entregar um rascunho cheio de erro porque confiou demais na ferramenta",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c33",
      "document_id": "doc-4",
      "code_id": "code-c2",
      "span_start": 610,
      "span_end": 689,
      "quote": "falta um treinamento mais sério aqui no escritório sobre como usar isso direito",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c34",
      "document_id": "doc-4",
      "code_id": "code-c1",
      "span_start": 893,
      "span_end": 970,
      "quote": "ainda tem muito sócio mais antigo aqui que trata isso como modinha passageira",
