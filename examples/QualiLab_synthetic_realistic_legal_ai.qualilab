      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c30",
      "document_id": "doc-4",
      "code_id": "code-e1",
      "span_start": 15,
      "span_end": 28,
      "quote": "Beatriz Lemos",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c31",
      "document_id": "doc-4",
      "code_id": "code-a3",
      "span_start": 305,
      "span_end": 383,
      "quote": "eu peço pra explicar um instituto jurídico que eu não entendi bem na faculdade",
