      "document_id": "doc-2",
      "code_id": "code-b1",
      "span_start": 965,
      "span_end": 1031,
      "quote": "um advogado que citou uma jurisprudência inventada pela ferramenta",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c19",
      "document_id": "doc-2",
      "code_id": "code-c2",
      "span_start": 1113,
      "span_end": 1178,
      "quote": "a gente não teve nenhum treinamento formal, foi tudo no improviso",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c20",
      "document_id": "doc-2",
      "code_id": "code-c3",
      "span_start": 1227,
      "span_end": 1279,
      "quote": "o escritório ainda não tem uma política clara de uso",
