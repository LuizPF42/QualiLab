    {
      "id": "v108",
      "document_id": "doc-1",
      "category_id": "cat-resumo",
      "value": "Sócia fundadora cética por experiência de citação inventada; admite uso restrito e regrado (rascunho e resumo, nunca citação sem checagem). Confidencialidade em M&A é o principal freio à adoção ampla.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v109",
      "document_id": "doc-3",
      "category_id": "cat-resumo",
      "value": "Sócio favorável, movido por pressão competitiva de clientes; condiciona uso à ausência de restrição contratual de confidencialidade. Considera o pânico com alucinação exagerado — o erro é de processo, não da ferramenta.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v110",
      "document_id": "doc-6",
      "category_id": "cat-resumo",
      "value": "Associado sênior em posição-ponte entre gerações; enfatiza responsabilidade do advogado que assina e veto a uso em clientes do setor financeiro.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v111",
      "document_id": "doc-7",
      "category_id": "cat-resumo",
      "value": "Sócio de inovação: trata adoção como problema de governança e cultura, não de tecnologia. Política interna + licença corporativa sem treinamento + trilha de capacitação obrigatória como resposta.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v112",
      "document_id": "doc-9",
      "category_id": "cat-resumo",
      "value": "Documento normativo do escritório: ferramentas autorizadas, vedação de dados de cliente, revisão humana obrigatória de citações e capacitação como pré-requisito de uso.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    }
  ],
