    },
    {
      "id": "c40",
      "document_id": "doc-5",
      "code_id": "code-c1",
      "span_start": 691,
      "span_end": 739,
      "quote": "Os associados mais novos adotaram isso rapidinho",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c41",
      "document_id": "doc-5",
      "code_id": "code-d0",
      "span_start": 1052,
      "span_end": 1145,
      "quote": "contencioso de massa se beneficia muito mais do que trabalho mais personalizado e estratégico",
      "layer": "final",
