      "author_name": "Marina"
    },
    {
      "id": "c25",
      "document_id": "doc-3",
      "code_id": "code-a2",
      "span_start": 514,
      "span_end": 542,
      "quote": "uma pressão competitiva real",
      "layer": "individual",
      "author_name": "Júlia"
    },
    {
      "id": "c26",
      "document_id": "doc-3",
      "code_id": "code-b3",
      "span_start": 713,
      "span_end": 766,
      "quote": "nenhum documento saia da infraestrutura interna deles",
      "layer": "individual",
      "author_name": "Marina"
    },
    {
      "id": "c27",
      "document_id": "doc-3",
      "code_id": "code-b3",
      "span_start": 713,
      "span_end": 766,
      "quote": "nenhum documento saia da infraestrutura interna deles",
      "layer": "individual",
      "author_name": "Rafael"
    },
    {
      "id": "c28",
      "document_id": "doc-3",
      "code_id": "code-b1",
      "span_start": 1247,
      "span_end": 1330,
      "quote": "O problema nunca foi a ferramenta errar, o problema é alguém usar sem checar depois",
      "layer": "final",
