    },
    {
      "id": "c24",
      "document_id": "doc-3",
      "code_id": "code-a2",
      "span_start": 223,
      "span_end": 308,
      "quote": "Os nossos clientes corporativos já perguntam diretamente se a gente usa IA generativa",
