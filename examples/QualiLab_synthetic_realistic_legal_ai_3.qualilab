      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v35",
      "document_id": "doc-5",
      "category_id": "cat-resumo",
      "value": "Sócia favorável com método: lidera treinamento na filial. Mostra como política e capacitação reduzem o medo de confidencialidade e aproximam as gerações.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v36",
      "document_id": "doc-6",
      "category_id": "cat-tipo",
