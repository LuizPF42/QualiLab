      "layer": "final"
    },
    {
      "id": "v28",
      "document_id": "doc-4",
      "category_id": "cat-resumo",
      "value": "Estagiária que usa escondido do sócio. Sem treinamento, insegura com o erro da ferramenta e com medo concreto de perder espaço na carreira.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
    {
      "id": "v29",
