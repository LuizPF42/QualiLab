      "layer": "final"
    },
    {
      "id": "v49",
      "document_id": "doc-7",
      "category_id": "cat-resumo",
      "value": "Sócio de inovação que governa o uso por política. Vê a maior ruptura no modelo de negócio (fim da hora) e na formação do júnior; aposta em treinamento contínuo.",
      "set_by": "user-admin",
      "author_name": "Admin",
      "layer": "final"
    },
