  "documents": [
    {
      "id": "doc-1",
      "name": "ENT-01 — Entrevista com pesquisadora",
      "content": "Entrevista com pesquisadora sobre métodos. Ela descreveu o roteiro semiestruturado usado nas entrevistas e mencionou preocupações de LGPD quanto ao consentimento dos participantes. Ao final, destacou um achado inesperado sobre anonimização de dados sensíveis."
    },
    {
      "id": "doc-2",
      "name": "OBS-01 — Nota de campo da observação",
      "content": "Nota de campo da observação em laboratório. O pesquisador observou a rotina da equipe e anotou aspectos éticos relacionados ao consentimento informado. Não houve menção a LGPD neste registro, mas o achado sobre cultura organizacional foi relevante."
    },
    {
      "id": "doc-3",
      "name": "DOC-01 — Protocolo do comitê de ética",
      "content": "Documento administrativo descrevendo o protocolo de anonimização adotado pelo comitê de ética. O texto cita o consentimento livre e esclarecido e referencia brevemente a entrevista piloto realizada antes da coleta principal."
    }
  ],
